{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Teshuva User Profile",
  "type": "object",
  "required": ["version", "id", "preferences", "history"],
  "properties": {
    "version":   { "type": "string" },
    "id":        { "type": "string" },
    "createdAt": { "type": ["string", "null"], "format": "date-time" },
    "updatedAt": { "type": ["string", "null"], "format": "date-time" },
    "preferences": {
      "type": "object",
      "properties": {
        "language":             { "type": "string", "enum": ["he", "en", "ar"] },
        "mascot":               { "type": "string" },
        "skin":                 { "type": "string" },
        "speakCooldownMs":      { "type": "number" },
        "idleIntervalMs":       { "type": "number" },
        "showOnboarding":       { "type": "boolean" },
        "notificationsEnabled": { "type": "boolean" }
      }
    },
    "history": {
      "type": "object",
      "properties": {
        "allTime":     { "type": "object", "additionalProperties": { "type": "number" } },
        "weights":     { "type": "object", "additionalProperties": { "type": "number" } },
        "totalSeen":   { "type": "number" },
        "firstSeenAt": { "type": ["string", "null"] },
        "lastSeenAt":  { "type": ["string", "null"] }
      }
    },
    "behavior": {
      "type": "object",
      "properties": {
        "avgSessionLengthMin": { "type": "number" },
        "peakHour":            { "type": ["number", "null"] },
        "dominantCategory":    { "type": ["string", "null"] },
        "feedVariety":         { "type": "number" }
      }
    }
  }
}
